# WeBolt Studio — Apache configuration for Hostinger
# Ensures all .html pages are served correctly

Options -Indexes
DirectoryIndex index.html

# ── Character encoding ─────────────────────────────
AddDefaultCharset UTF-8

# ── MIME types ─────────────────────────────────────
AddType text/html .html
AddType text/css .css
AddType application/javascript .js

# ── URL rewriting ──────────────────────────────────
RewriteEngine On

# Force HTTPS (uncomment once SSL is active on Hostinger)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Remove trailing slash for .html pages (prevents double-redirect loops)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Allow access to .html files — no stripping of extension
# If a clean URL /storitve is requested, serve storitve.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [L]

# ── Security headers ───────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Cache static assets ────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
</IfModule>

# ── Custom 404 ─────────────────────────────────────
ErrorDocument 404 /404.html
